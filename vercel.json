{
  "crons": [
    { "path": "/api/cron", "schedule": "* * * * *" }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/adjust.html",
      "dest": "/adjust.html"
    },
    {
      "src": "/adjust",
      "dest": "/adjust.html"
    },
    {
      "src": "/singular.html",
      "dest": "/singular.html"
    },
    {
      "src": "/singular",
      "dest": "/singular.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
